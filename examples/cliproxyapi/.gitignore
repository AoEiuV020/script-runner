# Local environment / secrets
.env
.env.*
!.env.example

# Local CLIProxyAPI config may contain API keys, proxy credentials, TLS paths, and other secrets
config/*
!config/config.example.yaml

# 放错位置的本地配置仍可能包含密钥；这里只用于防止误提交
/config.yaml
/config.*.yaml

# CLIProxyAPI home may contain account, auth, or runtime state
.cli-proxy-api/*
!.cli-proxy-api/.gitkeep

# Runtime output
logs/
tmp/
cache/
*.log

# macOS metadata
.DS_Store
