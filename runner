#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-run}"
shift || true

# shellcheck source=/usr/local/lib/runner/config.sh
source /usr/local/lib/runner/config.sh
# shellcheck source=/usr/local/lib/runner/commands.sh
source /usr/local/lib/runner/commands.sh

case "$cmd" in
  run)
    runner_cmd_run "$@"
    ;;
  update)
    runner_cmd_update "$@"
    ;;
  exec)
    runner_cmd_exec "$@"
    ;;
  show)
    runner_cmd_show
    ;;
  help|--help|-h)
    runner_cmd_help
    ;;
  *)
    echo "unknown command: $cmd" >&2
    runner_cmd_help >&2
    exit 1
    ;;
esac
